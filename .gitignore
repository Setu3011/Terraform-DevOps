# Open or create your .gitignore file and add these lines:
.terraform/
*.zip
*.exe

# Local .terraform directories
**/.terraform/*

# .tfstate files which contain sensitive credentials
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files if they contain sensitive data
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override directories
_override.tf/*

